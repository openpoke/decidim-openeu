            </li>
            <li>
              <input type="checkbox" name="group[70][2]" id="mce-group70-1" value="">
              <label for="mce-group70-1">Volunteering</label>
            </li>
            <li>
              <input type="checkbox" name="group[70][4]" id="mce-group70-2" value="">
              <label for="mce-group70-2">News</label>
            </li>
            <li>
              <input type="checkbox" name="group[70][8]" id="mce-group70-3" value="">
              <label for="mce-group70-3">Research</label>
            </li>
            <li>
              <input type="checkbox" name="group[70][16]" id="mce-group70-4" value="">
              <label for="mce-group70-4">Education</label>
            </li>
            <li>
              <input type="checkbox" name="group[70][32]" id="mce-group70-5" value="">
              <label for="mce-group70-5">Events</label>
            </li>
            <li>
              <input type="checkbox" name="group[70][64]" id="mce-group70-6" value="">
              <label for="mce-group70-6">Policy &amp; Advocacy</label>
            </li>
            <li>
              <input type="checkbox" name="group[70][128]" id="mce-group70-7" value="">
              <label for="mce-group70-7">Opportunities</label>
            </li>
          </ul>
        </div>

        <div class="mc-field-group">
          <label for="mce-MMERGE3">Audience <span class="asterisk">*</span></label>
          <select name="MMERGE3" class="required" id="mce-MMERGE3" required>

            <option value="Alliance member">Alliance member</option>
            <option value="External stakeholder">External stakeholder</option>
            <option value="Student">Student</option>
            <option value="Staff">Staff</option>
          </select>
        </div>

        <div id="mergeRow-gdpr" class="mergeRow gdpr-mergeRow content__gdprBlock mc-field-group">
          <div class="content__gdpr [&_a]:underline [&_a:hover]:font-semibold">
            <label class="text-lg font-semibold">GDPR</label>

            <p class="text-md mb-4">
              <a href="https://blogs.uned.es/openeu/terms-of-service/" target="_blank" rel="noopener noreferrer">Terms of Service</a><br>
              <a href="https://www.uoc.edu/portal/en/_peu/avis_legal/politica-privacitat/index.html" target="_blank" rel="noopener noreferrer">Privacy Policy</a>
            </p>

            <fieldset class="mc_fieldset gdprRequired mc-field-group" name="interestgroup_field">
